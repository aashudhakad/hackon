# ---- Server ----
PORT=4000
NODE_ENV=development
# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# ---- MongoDB Atlas ----
MONGODB_URI=mongodb://127.0.0.1:27017/amazon-instant-engine
MONGODB_DB_NAME=amazon-instant-engine

# ---- Redis ----
REDIS_URL=redis://127.0.0.1:6379
# Bundle cache TTL in seconds
BUNDLE_CACHE_TTL_SECONDS=3600

# ---- Multi-modal LLM API ----
# When LLM_API_KEY is empty, the backend uses a deterministic local stub
# so the system is fully runnable without external credentials.
LLM_API_KEY=
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ---- Gemini (text intent -> categories) ----
# Used by /api/normal and /api/quick to map a free-text intent (any language)
# to the relevant product categories. Falls back to a local matcher if empty.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ---- Timeout budgets (milliseconds) ----
INTENT_PARSER_TIMEOUT_MS=5000
VISION_TIMEOUT_MS=30000
AUDIO_INTENT_TIMEOUT_MS=30000
LLM_RESPONSE_TIMEOUT_MS=10000
CHECKOUT_TIMEOUT_MS=30000

# ---- Retry / limits ----
LLM_MAX_RETRIES=3
MAX_INTENT_CHARS=500
INTENT_BAR_CHAR_CAP=200
MAX_IMAGE_BYTES=10485760
MAX_AUDIO_BYTES=10485760
